# Supabase (required for data storage)
# Create a project at https://supabase.com, then run the SQL below in the SQL Editor to create the table.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional. GitHub Actions sets this for production (OAuth redirect). Leave unset locally — the app uses the current origin (e.g. http://localhost:3000).
# VITE_SITE_URL=https://planner.sergioagosti.org
